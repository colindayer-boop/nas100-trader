# OANDA practice account — oanda.com → My Account → API Access
OANDA_API_KEY=your-oanda-api-key-here
OANDA_ACCOUNT_ID=your-account-id-here   # looks like: 101-001-12345678-001

# Telegram bot — message @BotFather to create bot, get token
# Then message your bot once, visit: api.telegram.org/bot<TOKEN>/getUpdates to get chat_id
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
TELEGRAM_CHAT_ID=987654321
